<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Resources</title>
    <link rel="stylesheet" href="/css/resources.css">
    <link rel="stylesheet" href="/fontawesome/css/all.min.css">
</head>
<body>
    <%
    const resources = [
        {
            title: "Notes",
            icon: "fa-book-open",
            description: "Lecture notes, handwritten notes and study material.",
            url: `/resources/${subject}/notes`
        },
        {
            title: "Assignments",
            icon: "fa-file-lines",
            description: "College assignments and practice questions.",
            url: `/resources/${subject}/assignments`
        },
        {
            title: "Book",
            icon: "fa-book",
            description: "Recommended books and reference materials.",
            url: `/resources/${subject}/book`
        },
        {
            title: "Lesson Plan",
            icon: "fa-calendar-days",
            description: "Weekly lesson plan and syllabus schedule.",
            url: `/resources/${subject}/lesson-plan`
        },
        {
            title: "Previous Year Questions",
            icon: "fa-folder-open",
            description: "University previous year question papers.",
            url: `/resources/${subject}/pyq`
        },
        {
            title: "Quiz",
            icon: "fa-graduation-cap",
            description: "Practice quizzes to test your preparation.",
            url: `/resources/${subject}/quiz`
        }
    ];
    %>

    <div class="overlay" id="overlay" onclick="toggleSidebar()"></div>
    <!-- ================= Sidebar ================= -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-top">
            <div class="profile-img">
                <i class="fa-solid fa-user"></i>
            </div>

            <h3>Hello,</h3>
            <h2><%= user.username %></h2>
        </div>

        <nav class="sidebar-menu">
            <a href="/back-to-dashboard/<%= user.username %>">
                <i class="fa-solid fa-house"></i>
                <span>Dashboard</span>
            </a>
            <a href="/profile/<%= user.username %>">
                <i class="fa-solid fa-user"></i>
                <span>Profile</span>
            </a>
            <a href="#">
                <i class="fa-solid fa-crown"></i>
                <span>Subscription</span>
            </a>
            <a href="#">
                <i class="fa-solid fa-star"></i>
                <span>Star</span>
            </a>
            <a href="/support/<%= user.username %>">
                <i class="fa-solid fa-headset"></i>
                <span>Support</span>
            </a>
        </nav>

        <div class="sidebar-bottom">
            <a href="/logout/<%= user.username %>" class="logout-btn">
                <i class="fa-solid fa-right-from-bracket"></i>
                <span>Log Out</span>
            </a>
        </div>
    </aside>

    <!-- ================= Main ================= -->
    <main class="main" id="main">
        <header class="topbar">
            <button class="menu-btn" onclick="toggleSidebar()">
                <i class="fa-solid fa-bars"></i>
            </button>

            <a href="javascript:history.back()" class="back-btn">
                <i class="fa-solid fa-arrow-left"></i>
                Back
            </a>
        </header>

        <!-- Hero -->
        <section class="hero">
            <div class="hero-text">
                <h1><%= subject %></h1>
                <p>Select the resource you want to access.</p>
            </div>
        </section>

        <!-- Resource Cards -->
        <section class="resource-grid">
            <% resources.forEach(resource => { %>
                <a href="<%= resource.url %>" class="resource-card">
                    <div class="card-icon">
                        <i class="fa-solid <%= resource.icon %>"></i>
                    </div>

                    <div class="card-content">
                        <h2><%= resource.title %></h2>
                        <p><%= resource.description %></p>
                    </div>

                    <div class="card-arrow">
                        <i class="fa-solid fa-arrow-right"></i>
                    </div>
                </a>
            <% }) %>
        </section>
    </main>

    <script src="/js/resources.js"></script>

</body>
</html>