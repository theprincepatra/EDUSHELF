                            <small>|</small>
                            <p>EDUSHELF</p>
                        </div>

                        <div class="top-section">
                            <img src="/images/cards/cse.png" alt="cse">
                        </div>

                        <div class="bottom-section">
                            <h2>CSE</h2>
                            <div class="row">
                                <div class="item">
                                    <span class="big-text">Notes</span>
                                </div>

                                <div class="item">
                                    <span class="big-text">Assignments</span>
                                </div>

                                <div class="item">
                                    <span class="big-text">PYQ's</span>
                                </div>
                            </div>
                        </div>
                    </div></a>

                    <!-- 2 -->
                    <a href="/aiml"><div class="card">
                        <div class="card-logo">
                            <img src="/images/logo_bgremove.png" class="card-logo" alt="ED-Card-logo">
