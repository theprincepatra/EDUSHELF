                        <div class="card-logo">
                            <img src="/images/logo_bgremove.png" class="card-logo" alt="ED-Card-logo">
                            <small>|</small>
                            <p>EDUSHELF</p>
                        </div>

                        <div class="top-section it-bg">
                            <img src="/images/cards/it.png" alt="it">
                        </div>

                        <div class="bottom-section">
