            <!-- PROFILE SECTION -->
            <div id="profile" class="section">
                <h1>Profile Page</h1>
            </div>

            <div id="subscription" class="section">
                <h1>Subscription Page</h1>
            </div>

            <div id="star" class="section">
                <h1>Star Page</h1>
            </div>
        </div>
    </div>

    <!-- NAVBAR -->
    <div class="nav">
        <div class="nav_ins">

            <div class="name">
                <img src="/images/logo_bgremove.png" class="logo" alt="EDlogo">

                <div class="small">
                    <p class="edushelf">EDUSHELF</p>
                    <small>Click to know about us</small>
                </div>
            </div>

            <div class="nav_items">

                <div class="search_box">
                    <img src="/images/search.png" alt="Search Icon" class="search_icon">
                    <input type="search" placeholder="Search" class="search">
                </div>

                <div class="items">
                    <a href="/subscription/<%= user.username %>">Subscription</a>
                    <a href="/star/<%= user.username %>">Star</a>
                </div>

            </div>

            <div class="help">
                <a href="/support/<%= user.username %>">Edu-Support</a>
            </div>

        </div>
    </div>

    <!-- PROFILE IMAGE -->
    <div class="image">
        <a href="/profile/<%= user.username %>"><img src="/images/default-profile.png" alt="User Icon"
                class="user_icon"></a>
    </div>



    <script src="/js/dashboard.js"></script>

