<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DASHBOARD</title>
    <link rel="stylesheet" href="/css/dashboard.css">
</head>

<body>

    <!-- MENU BUTTON -->
    <div class="menu-btn" onclick="toggleMenu()">☰</div>

    <div class="all">

        <!-- SIDE BAR -->
        <div class="sidebar" id="sidebar">
            <div class="designation">
                <h3>Hello</h3>
                <h2>
                    <%= user.username %>
                </h2>
            </div>

            <div class="sidebar-items">
                <a onclick="showSection('dashboard')">Dashboard</a>
                <a onclick="showSection('profile')">Profile</a>
                <a onclick="showSection('subscription')">Subscription</a>
                <a onclick="showSection('star')">Star</a>
                <a href="/support/<%= user.username %>">Support</a>
            </div>

            <button class="logout"><a href="/logout/<%= user.username %>">Log Out</a></button>

        </div>

        <!-- MAIN CONTENT -->
