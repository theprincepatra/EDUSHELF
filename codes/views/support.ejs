<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Support Center</title>
    <link rel="stylesheet" href="/css/support.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
</head>

<body>

    <nav class="navbar">
        <div class="logo">
            <img src="/images/logo_bgremove.png">
            <h2>EDUSHELF <span>Support Center</span></h2>
        </div>

        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/downloads">Downloads</a>
            <a href="/subscription">Subscription</a>
        </div>
    </nav>

    <section class="hero">

        <div class="left">

            <h1>How can we help you?</h1>

            <p>
                Need help with your account, payment, subscription or found a bug?
                Tell us your issue and our team will get back to you soon.
            </p>

            <form id="supportForm">

                <label>Issue Category</label>

                <select id="category" required>
                    <option value="">Select Category</option>
                    <option>General Inquiry</option>
                    <option>Account Issue</option>
                    <option>Payment Issue</option>
                    <option>Subscription Issue</option>
                    <option>Technical Issue</option>
                    <option>Bug Report</option>
                    <option>Feature Request</option>
                    <option>Other</option>
                </select>

                <label>Subject</label>

                <input type="text" id="subject" placeholder="Enter issue title" required>

                <label>Describe your issue</label>

                <textarea id="message" placeholder="Explain your issue in detail..." required></textarea>

                <label>Attach Screenshot (Optional)</label>

                <input type="file" id="image" accept="image/*">

                <button type="submit">
                    Submit Support Request
                </button>

            </form>

        </div>

        <div class="right">

            <img src="/images/support/doodle.png" class="doodle">

        </div>

    </section>

    <section class="quick-help">

        <div class="card" data-category="General Inquiry">
            <i class="fa-regular fa-comments"></i>
            <h3>General</h3>
            <p>Questions about EduShelf.</p>
        </div>

        <div class="card" data-category="Account Issue">
            <i class="fa-solid fa-user"></i>
            <h3>Account</h3>
            <p>Login & profile problems.</p>
        </div>

        <div class="card" data-category="Payment Issue">
            <i class="fa-solid fa-credit-card"></i>
            <h3>Payment</h3>
            <p>Payment & refund issues.</p>
        </div>

        <div class="card" data-category="Technical Issue">
            <i class="fa-solid fa-laptop-code"></i>
            <h3>Technical</h3>
            <p>Website bugs & errors.</p>
        </div>

    </section>

    <script src="/js/support.js"></script>

</body>

</html>