<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password</title>

    <link rel="stylesheet" href="/css/forgot-password.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/fontawesome/css/all.min.css">
</head>
<body>

<div class="container">

    <div class="left">

        <img src="/images/logo_bgremove.png" class="logo">

        <h1>EDUSHELF</h1>

        <p>
            Student Learning Platform
        </p>

    </div>

    <div class="right">

        <h2>Forgot Password</h2>
        <div id="messageBox" class="message-box"></div>

        <p class="subtitle">
            Enter your registered email address. We'll send you a One-Time Password (OTP) for verification.
        </p>

        <!-- EMAIL SECTION -->

        <div class="section">
            <label>Registered Email</label>
            <div class="input-box">
                <i class="fa-solid fa-envelope"></i>
                <input type="email" id="email" name="email" autocomplete="email" placeholder="Enter your registered email">
            </div>

            <button id="sendOtp">Send OTP</button>
        </div>

        <!-- OTP SECTION -->
        <div class="section otp-section" id="otpSection">
            <label>Enter OTP</label>
            <div class="otp-box">
                <input maxlength="1" class="otp">
                <input maxlength="1" class="otp">
                <input maxlength="1" class="otp">
                <input maxlength="1" class="otp">
                <input maxlength="1" class="otp">
                <input maxlength="1" class="otp">
            </div>

            <div class="otp-footer">
                <span id="timer">Resend OTP in 30s</span>
                <a href="#" id="resendOtp">Resend OTP</a>
            </div>

            <button id="verifyOtp">Verify OTP</button>
        </div>

        <!-- PASSWORD SECTION -->
        <div class="section password-section" id="passwordSection">
            <label>New Password</label>
            <p id="passwordError" class="password-error"></p>

            <div class="input-box">
                <i class="fa-solid fa-lock"></i>
                <input type="password" placeholder="Enter new password" autocomplete="new-password">
                <i class="fa-solid fa-eye toggle"></i>
            </div>

            <label>Confirm Password</label>
            <div class="input-box">
                <i class="fa-solid fa-lock"></i>
                <input type="password" placeholder="Confirm new password" autocomplete="new-password">
                <i class="fa-solid fa-eye toggle"></i>
            </div>

            <button>Reset Password</button>
        </div>

        <a href="/login" class="back">
            <i class="fa-solid fa-arrow-left"></i>
            Back to Login
        </a>
    </div>
</div>

<script src="/js/forgot-password.js"></script>

</body>
</html>