<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Change Password</title>
<link rel="stylesheet" href="/css/change-password.css">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
</head>
<body>
    <div class="container">
        <div class="left">
            <img src="/images/logo_bgremove.png" class="logo">
            <h1>EDUSHELF</h1>
            <p>Student Learning Platform</p>
        </div>

        <div class="right">
            <h2>Change Password</h2>

            <div id="messageBox" class="message-box"></div>
            <p class="subtitle">
            Update your account password securely by entering your current password and choosing a new password.
            </p>
            <div class="section">

                <label>Current Password</label>
                <div class="input-box">
                    <i class="fa-solid fa-lock"></i>
                    <input type="password" id="currentPassword" placeholder="Enter current password" autocomplete="current-password">
                    <i class="fa-solid fa-eye toggle"></i>
                </div>

                <label>New Password</label>
                <p id="passwordError" class="password-error"></p>
                <div class="input-box">
                    <i class="fa-solid fa-lock"></i>
                    <input type="password" id="newPassword" placeholder="Enter new password" autocomplete="new-password">
                    <i class="fa-solid fa-eye toggle"></i>
                </div>

                <label>Confirm Password</label>
                <div class="input-box">
                    <i class="fa-solid fa-lock"></i>
                    <input type="password" id="confirmPassword" placeholder="Confirm new password" autocomplete="new-password">
                    <i class="fa-solid fa-eye toggle"></i>
                </div>
                <button id="changePassword">Change Password</button>
            </div>

            <a href="/password" class="back"><i class="fa-solid fa-arrow-left"></i>Back to Password Settings</a>
        </div>
    </div>

    <script src="/js/change-password.js"></script>

</body>
</html>