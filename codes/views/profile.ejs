<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile Dashboard</title>
    <link rel="stylesheet" href="/css/profile.css">
</head>
<body>

<div class="container">

    <!-- LEFT CARD -->
    <div class="profile-card">

        <div class="profile-top">

            <div class="profile-image-wrapper">
                <img src="/images/dashboard/default-profile.png" class="profile-image">

                <button class="edit-btn">
                    <img src="/images/dashboard/pencil.png">
                </button>
            </div>

            <h2><%= user.name %></h2>

            <div class="user-box">

                <div class="user-row">
                    <div class="detail-left">
                        <img src="/images/dashboard/username.png">
                        <p>Username</p>
                    </div>
                    <span><%= user.username %></span>
                </div>
                <div class="user-row">
                    <div class="detail-left">
                        <img src="/images/dashboard/userid.png">
                        <p>User ID</p>
                    </div>
                    <span><%= user.userId %></span>
                </div>
                <div class="user-row">
                    <div class="detail-left">
                        <img src="/images/dashboard/userid.png">
                        <p>Referral Code</p>
                    </div>
                    <span><%= user.referralCode %></span>
                </div>

            </div>
        </div>

        <div class="profile-details">

            <div class="detail-row">
                <div class="detail-left">
                    <img src="/images/dashboard/email.png">
                    <span>Email</span>
                </div>
                <span><%= user.email %></span>
            </div>

            <div class="detail-row">
                <div class="detail-left">
                    <img src="/images/dashboard/phone.png">
                    <span>Phone</span>
                </div>
                <span><%= user.phone %></span>
            </div>

            <div class="detail-row">
                <div class="detail-left">
                    <img src="/images/dashboard/college.png">
                    <span>College</span>
                </div>
                <span><%= user.college %></span>
            </div>

            <div class="detail-row">
                <div class="detail-left">
                    <img src="/images/dashboard/branch.png">
                    <span>Branch</span>
                </div>
                <span><%= user.branch %></span>
            </div>

            <div class="detail-row">
                <div class="detail-left">
                    <img src="/images/dashboard/semester.png">
                    <span>Semester</span>
                </div>
                <span><%= user.semester %></span>
            </div>

        </div>

        <button class="main-btn editprofile-btn">Edit Profile</button>

    </div>


    <!-- RIGHT SIDE -->
    <div class="right-section">

        <!-- ACCOUNT SECURITY -->
        <div class="card">
            <h2>Account & Security</h2>

            <div class="security-item">
                <div class="security-icon purple">
                    <img src="/images/dashboard/call-verified.png">
                </div>
                <div class="security-content">
                    <h4>Phone Verified</h4>
                    <p>Verified</p>
                </div>
            </div>

            <div class="security-item">
                <div class="security-icon purple">
                    <img src="/images/dashboard/email-verified.png">
                </div>
                <div class="security-content">
                    <h4>Email Verified</h4>
                    <p>Verified</p>
                </div>
            </div>

            <div class="two-in-one">
                <div class="security-item bothbox">
                    <div class="security-icon blue">
                        <img src="/images/dashboard/joinedon.png">
                    </div>
                    <div class="security-content">
                        <h4>Joined On</h4>
                        <p>14 Jan 2025</p>
                    </div>
                </div>
                <div class="security-item bothbox">
                    <div class="security-icon orange">
                        <img src="/images/dashboard/last-login.png">
                    </div>
                    <div class="security-content">
                        <h4>Last Login</h4>
                        <p>Today</p>
                    </div>
                </div>
            </div>

            <div class="button-group">

                <button class="changepassword-btn">
                    <img src="/images/dashboard/password.png">
                    Change Password
                </button>

                <button class="main-btn">
                    <img src="/images/dashboard/verify.png">
                    Verify Email
                </button>

            </div>

        </div>

        <!-- MY OVERVIEW -->
        <div class="card">

            <h2>My Overview</h2>

            <div class="overview-grid">

                <div class="overview-box subscription">
                    <img src="/images/dashboard/subscription.png">
                    <h3>12</h3>
                    <p>Subscriptions</p>
                </div>

                <div class="overview-box save">
                    <img src="/images/dashboard/star.png">
                    <h3>8</h3>
                    <p>Saved Notes</p>
                </div>

                <div class="overview-box download">
                    <img src="/images/dashboard/download.png">
                    <h3>25</h3>
                    <p>Downloads</p>
                </div>

                <div class="overview-box refer">
                    <img src="/images/dashboard/refer.png">
                    <h3>5</h3>
                    <p>Referrals</p>
                </div>

            </div>

        </div>

    </div>

</div>

</body>
</html>