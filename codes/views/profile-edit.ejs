<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Profile</title>
    <link rel="stylesheet" href="/css/profile-edit.css">
</head>
<body>
    <div class="container">
        <div class="edit-card">
            <div class="header">
                <h1>Edit Profile</h1>
                <p>Update your personal information</p>
            </div>

            <form action="/profile/edit" method="POST" enctype="multipart/form-data">
                <div class="profile-section">
                    <div class="image-wrapper">
                        <img
                            id="profilePreview"
                            src="<%= user.profilepicture %>"
                            class="profile-image">
                        <label for="profilepicture" class="upload-btn">
                            Change Photo
                        </label>
                        <input type="file" id="profilepicture" name="profilepicture" hidden>
                    </div>
                </div>

                <div class="form-grid">

                    <div class="input-group">
                        <label>Full Name</label>
                        <input type="text" name="name" value="<%= user.name %>" required>
                    </div>
                    <div class="input-group">
                        <label>UserName</label>
                        <input type="text" name="username" value="<%= user.username %>" required>
                    </div>
                    <div class="input-group">
                        <label>Date of Birth</label>
                        <input type="date" name="dob" value="<%= user.dob ? user.dob.toISOString().split('T')[0] : '' %>" required>
                    </div>
                    <div class="input-group">
                        <label>Phone Number</label>
                        <input type="text" name="phone" value="<%= user.phone || '' %>">
                    </div>
                    <div class="input-group">
                        <label>Semester</label>
                        <select name="semester" required>
                            <option value="">Select Semester</option>

                            <option value="1" <%= user.semester == 1 ? 'selected' : '' %>>1st Semester</option>
                            <option value="2" <%= user.semester == 2 ? 'selected' : '' %>>2nd Semester</option>
                            <option value="3" <%= user.semester == 3 ? 'selected' : '' %>>3rd Semester</option>
                            <option value="4" <%= user.semester == 4 ? 'selected' : '' %>>4th Semester</option>
                            <option value="5" <%= user.semester == 5 ? 'selected' : '' %>>5th Semester</option>
                            <option value="6" <%= user.semester == 6 ? 'selected' : '' %>>6th Semester</option>
                            <option value="7" <%= user.semester == 7 ? 'selected' : '' %>>7th Semester</option>
                            <option value="8" <%= user.semester == 8 ? 'selected' : '' %>>8th Semester</option>
                        </select>
                    </div>

                    <div class="input-group">
                        <label>Branch</label>
                        <select name="branch" required>
                            <option value="">Select Branch</option>

                            <option value="CSE" <%= user.branch === 'CSE' ? 'selected' : '' %>>CSE</option>
                            <option value="CSE AIML" <%= user.branch === 'CSE AIML' ? 'selected' : '' %>>CSE AIML</option>
                            <option value="CSE IT" <%= user.branch === 'CSE IT' ? 'selected' : '' %>>CSE IT</option>
                            <option value="Data Science" <%= user.branch === 'Data Science' ? 'selected' : '' %>>Data Science</option>
                            <option value="Cyber Security" <%= user.branch === 'Cyber Security' ? 'selected' : '' %>>Cyber Security</option>
                            <option value="Civil" <%= user.branch === 'Civil' ? 'selected' : '' %>>Civil</option>
                            <option value="ECE" <%= user.branch === 'ECE' ? 'selected' : '' %>>ECE</option>
                            <option value="EE" <%=user.branch === 'EE' ? 'selected' : '' %>>EE</option>
                            <option value="Mechanical" <%= user.branch === 'Mechanical' ? 'selected' : '' %>>Mechanical</option>
                        </select>
                    </div>
                </div>

                <div class="readonly-box">
                    <h3>Account Information</h3>

                    <div class="readonly-row">
                        <span>Username</span>
                        <p><%= user.username %></p>
                    </div>
                    <div class="readonly-row">
                        <span>User ID</span>
                        <p><%= user.userId %></p>
                    </div>
                    <div class="readonly-row">
                        <span>Email</span>
                        <p><%= user.email %></p>
                    </div>
                    <div class="readonly-row">
                        <span>Referral Code</span>
                        <p><%= user.referralCode %></p>
                    </div>
                </div>

                <div class="button-group">
                    <a href="/profile/<%= user.username %>" class="cancel-btn">
                        Cancel
                    </a>
                    <button type="submit" class="save-btn">
                        Save Changes
                    </button>
                </div>

            </form>
        </div>
    </div>

    <script src="/js/profile-edit.js"></script>
</body>
</html>